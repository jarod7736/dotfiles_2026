<h2>Light Card — Revised</h2>
<p class="subtitle">2-column grid kept. Toggle top-right, slider below name.</p>

<div class="mockup">
  <div class="mockup-header">Living Room — Lights section</div>
  <div class="mockup-body" style="background:#0f1117;padding:16px;font-family:system-ui,sans-serif;">

    <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.3);margin-bottom:10px;padding:0 2px;">Lights</div>

