<h2>Light Card Design Options</h2>
<p class="subtitle">Each card needs a brightness slider + on/off toggle — separated so they don't conflict</p>

<div class="cards">

  <!-- Option A -->
  <div class="card" data-choice="a" onclick="toggleSelect(this)">
    <div class="card-image" style="background:#1a1d27;padding:16px;border-radius:8px;">
      <!-- Card A: Stacked — toggle top-right, slider below -->
      <div style="background:#1e2130;border-radius:14px;padding:14px 16px;font-family:system-ui,sans-serif;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:18px;">💡</span>
            <span style="color:#e2e8f0;font-size:13px;font-weight:500;">Living Room Lights</span>
          </div>
          <!-- Toggle switch ON -->
          <div style="width:44px;height:24px;background:#f59e0b;border-radius:12px;position:relative;flex-shrink:0;">
            <div style="width:20px;height:20px;background:white;border-radius:50%;position:absolute;top:2px;right:2px;"></div>
          </div>
        </div>
        <div style="position:relative;height:6px;background:#374151;border-radius:3px;">
          <div style="width:70%;height:100%;background:#f59e0b;border-radius:3px;"></div>
          <div style="width:18px;height:18px;background:white;border:2px solid #f59e0b;border-radius:50%;position:absolute;top:-6px;left:calc(70% - 9px);"></div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:6px;">
          <span style="color:#6b7280;font-size:10px;">0%</span>
          <span style="color:#f59e0b;font-size:11px;font-weight:600;">70%</span>
          <span style="color:#6b7280;font-size:10px;">100%</span>
        </div>
      </div>
      <!-- Second card OFF state -->
      <div style="background:#1e2130;border-radius:14px;padding:14px 16px;margin-top:8px;font-family:system-ui,sans-serif;opacity:0.6;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:18px;filter:grayscale(1);">💡</span>
            <span style="color:#6b7280;font-size:13px;font-weight:500;">Floor Lamp</span>
          </div>
          <div style="width:44px;height:24px;background:#374151;border-radius:12px;position:relative;flex-shrink:0;">
            <div style="width:20px;height:20px;background:#9ca3af;border-radius:50%;position:absolute;top:2px;left:2px;"></div>
          </div>
        </div>
        <div style="height:6px;background:#374151;border-radius:3px;opacity:0.4;"></div>
      </div>
    </div>
    <div class="card-body">
      <h3>A — Compact stacked</h3>
      <p>Toggle top-right, slider below. Full-width cards in a single column. Toggle and slider are separate touch targets — no conflict.</p>
    </div>
  </div>

  <!-- Option B -->
  <div class="card" data-choice="b" onclick="toggleSelect(this)">
    <div class="card-image" style="background:#1a1d27;padding:16px;border-radius:8px;">
      <!-- Card B: 2-col grid, icon+name+toggle on top row, slider spans full width -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-family:system-ui,sans-serif;">
        <div style="background:#1e2130;border-radius:14px;padding:12px;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
            <span style="font-size:20px;">💡</span>
            <div style="width:38px;height:20px;background:#f59e0b;border-radius:10px;position:relative;">
              <div style="width:16px;height:16px;background:white;border-radius:50%;position:absolute;top:2px;right:2px;"></div>
            </div>
          </div>
          <div style="color:#e2e8f0;font-size:11px;font-weight:500;margin-bottom:10px;">Ceiling</div>
          <div style="position:relative;height:5px;background:#374151;border-radius:3px;">
            <div style="width:80%;height:100%;background:#f59e0b;border-radius:3px;"></div>
            <div style="width:14px;height:14px;background:white;border:2px solid #f59e0b;border-radius:50%;position:absolute;top:-5px;left:calc(80% - 7px);"></div>
          </div>
        </div>
        <div style="background:#1e2130;border-radius:14px;padding:12px;opacity:0.55;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
            <span style="font-size:20px;filter:grayscale(1);">💡</span>
            <div style="width:38px;height:20px;background:#374151;border-radius:10px;position:relative;">
              <div style="width:16px;height:16px;background:#6b7280;border-radius:50%;position:absolute;top:2px;left:2px;"></div>
            </div>
          </div>
          <div style="color:#6b7280;font-size:11px;font-weight:500;margin-bottom:10px;">Floor Lamp</div>
          <div style="height:5px;background:#374151;border-radius:3px;opacity:0.4;"></div>
        </div>
        <div style="background:#1e2130;border-radius:14px;padding:12px;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
            <span style="font-size:20px;">💡</span>
            <div style="width:38px;height:20px;background:#f59e0b;border-radius:10px;position:relative;">
              <div style="width:16px;height:16px;background:white;border-radius:50%;position:absolute;top:2px;right:2px;"></div>
            </div>
          </div>
          <div style="color:#e2e8f0;font-size:11px;font-weight:500;margin-bottom:10px;">Accent</div>
          <div style="position:relative;height:5px;background:#374151;border-radius:3px;">
            <div style="width:40%;height:100%;background:#f59e0b;border-radius:3px;"></div>
            <div style="width:14px;height:14px;background:white;border:2px solid #f59e0b;border-radius:50%;position:absolute;top:-5px;left:calc(40% - 7px);"></div>
          </div>
        </div>
        <div style="background:#1e2130;border-radius:14px;padding:12px;opacity:0.55;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
            <span style="font-size:20px;filter:grayscale(1);">💡</span>
            <div style="width:38px;height:20px;background:#374151;border-radius:10px;position:relative;">
              <div style="width:16px;height:16px;background:#6b7280;border-radius:50%;position:absolute;top:2px;left:2px;"></div>
            </div>
          </div>
          <div style="color:#6b7280;font-size:11px;font-weight:500;margin-bottom:10px;">Table Lamp</div>
          <div style="height:5px;background:#374151;border-radius:3px;opacity:0.4;"></div>
        </div>
      </div>
    </div>
    <div class="card-body">
      <h3>B — 2-column grid (keep current layout)</h3>
      <p>Keeps the existing 2-col grid. Toggle in corner, slider at bottom of each card. More compact but slider is smaller.</p>
    </div>
  </div>

  <!-- Option C -->
  <div class="card" data-choice="c" onclick="toggleSelect(this)">
    <div class="card-image" style="background:#1a1d27;padding:16px;border-radius:8px;">
      <!-- Card C: Full-width row, icon left, name+slider in middle, toggle right -->
      <div style="display:flex;flex-direction:column;gap:8px;font-family:system-ui,sans-serif;">
        <div style="background:#1e2130;border-radius:14px;padding:12px 14px;display:flex;align-items:center;gap:12px;">
          <span style="font-size:20px;flex-shrink:0;">💡</span>
          <div style="flex:1;min-width:0;">
            <div style="color:#e2e8f0;font-size:12px;font-weight:500;margin-bottom:7px;">Living Room Lights</div>
            <div style="position:relative;height:5px;background:#374151;border-radius:3px;">
              <div style="width:65%;height:100%;background:#f59e0b;border-radius:3px;"></div>
              <div style="width:14px;height:14px;background:white;border:2px solid #f59e0b;border-radius:50%;position:absolute;top:-5px;left:calc(65% - 7px);"></div>
            </div>
          </div>
          <div style="width:44px;height:24px;background:#f59e0b;border-radius:12px;position:relative;flex-shrink:0;">
            <div style="width:20px;height:20px;background:white;border-radius:50%;position:absolute;top:2px;right:2px;"></div>
          </div>
        </div>
        <div style="background:#1e2130;border-radius:14px;padding:12px 14px;display:flex;align-items:center;gap:12px;opacity:0.55;">
          <span style="font-size:20px;flex-shrink:0;filter:grayscale(1);">💡</span>
          <div style="flex:1;min-width:0;">
            <div style="color:#6b7280;font-size:12px;font-weight:500;margin-bottom:7px;">Floor Lamp</div>
            <div style="height:5px;background:#374151;border-radius:3px;opacity:0.4;"></div>
          </div>
          <div style="width:44px;height:24px;background:#374151;border-radius:12px;position:relative;flex-shrink:0;">
            <div style="width:20px;height:20px;background:#6b7280;border-radius:50%;position:absolute;top:2px;left:2px;"></div>
          </div>
        </div>
        <div style="background:#1e2130;border-radius:14px;padding:12px 14px;display:flex;align-items:center;gap:12px;">
          <span style="font-size:20px;flex-shrink:0;">💡</span>
          <div style="flex:1;min-width:0;">
            <div style="color:#e2e8f0;font-size:12px;font-weight:500;margin-bottom:7px;">Accent Lights</div>
            <div style="position:relative;height:5px;background:#374151;border-radius:3px;">
              <div style="width:30%;height:100%;background:#f59e0b;border-radius:3px;"></div>
              <div style="width:14px;height:14px;background:white;border:2px solid #f59e0b;border-radius:50%;position:absolute;top:-5px;left:calc(30% - 7px);"></div>
            </div>
          </div>
          <div style="width:44px;height:24px;background:#f59e0b;border-radius:12px;position:relative;flex-shrink:0;">
            <div style="width:20px;height:20px;background:white;border-radius:50%;position:absolute;top:2px;right:2px;"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="card-body">
      <h3>C — Full-width rows</h3>
      <p>Each light is a horizontal row. Icon left, name + wide slider in the middle, toggle on the right. Slider gets the most horizontal space — easiest to drag.</p>
    </div>
  </div>

</div>

<p class="subtitle" style="margin-top:16px;">Click to select your preferred layout, or let me know in the terminal.</p>
