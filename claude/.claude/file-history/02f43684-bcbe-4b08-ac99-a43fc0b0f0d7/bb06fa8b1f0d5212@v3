import fetch from "node-fetch";
import { getFewShotExamples } from "./feedback.js";

const ANTHROPIC_API = "https://api.anthropic.com/v1/messages";
const MODEL = "claude-sonnet-4-6";

const FAMILY_CONTEXT = `
The recipient's full name is Jarod Belshaw. His wife is Leighanne Croft (also known as Mary Croft).
His children are Finnegan Belshaw and Olivia Belshaw. Emails personally addressed to any of these
names should receive elevated priority. Known contacts and recognized service domains rank higher
than unknown cold senders.
`.trim();

const CATEGORY_RULES = `
CATEGORIES:
- action:  Must actively do something — pay a bill, sign/approve, schedule, make a decision, fix an account issue, fill out a form
- respond: Someone is waiting on a reply — direct questions, personal messages, professional correspondence
- read:    Worth reading, no action needed — receipts, shipping, order confirmations, subscribed newsletters, service notifications
- ad:      Marketing, promotional, offers, sales, brand emails not specifically subscribed to for useful updates
- junk:    Spam, phishing, scam, unsolicited bulk mail, completely irrelevant, unknown sender

RULES:
1. Personally addressed to Jarod, Leighanne, Finnegan, or Olivia → elevate toward action/respond/read
2. Known senders / recognized domains for services Jarod uses → read or action
3. Unknown senders with generic pitches → ad or junk
4. Legal, financial, medical, government, insurance → almost always action or read
5. Be aggressive classifying obvious spam/phishing as junk
`.trim();

/**
 * Classify a batch of emails in a single API call.
 * @param {Array} emails - array of {id, from, subject, date, snippet, body?}
 * @returns {Array} - array of {id, category, reason, priority}
 */
export async function classifyBatch(emails) {
  if (!emails.length) return [];

  const emailList = emails.map((e, i) =>
    `[${i}] ID: ${e.id}\nFROM: ${e.from}\nSUBJECT: ${e.subject}\nDATE: ${e.date}\nSNIPPET: ${(e.snippet || e.body || "").substring(0, 400)}`
  ).join("\n\n---\n\n");

  const corrections = getFewShotExamples(15);
  const correctionBlock = corrections.length > 0
    ? `\nUSER CORRECTIONS (learn from these — the user overrode the AI's classification):\n` +
      corrections.map(c =>
        `FROM: ${c.from}\nSUBJECT: ${c.subject}\nSNIPPET: ${c.snippet}\nAI said: ${c.aiCategory} → User corrected to: ${c.userCategory}`
      ).join("\n\n") + "\n"
    : "";

  const prompt = `You are an email triage assistant. Classify each email below.

RECIPIENT CONTEXT:
${FAMILY_CONTEXT}

${CATEGORY_RULES}
${correctionBlock}
Return ONLY a raw JSON array, no markdown, no backticks, one object per email:
[{"index": 0, "id": "...", "category": "action|respond|read|ad|junk", "reason": "one sentence", "priority": 1-5}]

Priority scale: 5=urgent, 4=high, 3=normal, 2=low, 1=ignore

EMAILS TO CLASSIFY:
${emailList}`;

  const res = await fetch(ANTHROPIC_API, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-api-key": process.env.ANTHROPIC_API_KEY,
      "anthropic-version": "2023-06-01"
    },
    body: JSON.stringify({
      model: MODEL,
      max_tokens: 1000,
      messages: [{ role: "user", content: prompt }]
    })
  });

  if (!res.ok) {
    const err = await res.text();
    throw new Error(`Classifier API ${res.status}: ${err.substring(0, 200)}`);
  }

  const data = await res.json();
  const text = (data.content || []).filter(b => b.type === "text").map(b => b.text).join("");

  const match = text.match(/\[[\s\S]*\]/);
  if (!match) {
    // Fallback: mark all as read
    return emails.map(e => ({ id: e.id, category: "read", reason: "Classification unavailable", priority: 2 }));
  }

  try {
    const results = JSON.parse(match[0]);
    // Merge results back by index, fallback to email id matching
    return emails.map((email, i) => {
      const result = results.find(r => r.id === email.id || r.index === i);
      return result
        ? { id: email.id, category: result.category, reason: result.reason, priority: result.priority }
        : { id: email.id, category: "read", reason: "Not classified", priority: 2 };
    });
  } catch {
    return emails.map(e => ({ id: e.id, category: "read", reason: "Parse error", priority: 2 }));
  }
}

/**
 * Classify all emails in batches of 20
 */
export async function classifyAll(emails, onProgress) {
  const BATCH_SIZE = 20;
  const results = [];

  for (let i = 0; i < emails.length; i += BATCH_SIZE) {
    const batch = emails.slice(i, i + BATCH_SIZE);
    onProgress?.({ current: i, total: emails.length, phase: "Classifying" });

    const batchResults = await classifyBatch(batch);
    results.push(...batchResults);

    // Small delay between batches
    if (i + BATCH_SIZE < emails.length) {
      await new Promise(r => setTimeout(r, 500));
    }
  }

  onProgress?.({ current: emails.length, total: emails.length, phase: "Done" });
  return results;
}
