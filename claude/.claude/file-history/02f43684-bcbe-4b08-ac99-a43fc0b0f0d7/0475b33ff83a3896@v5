import "dotenv/config";
import express from "express";
import cors from "cors";
import { readFileSync, writeFileSync, mkdirSync, existsSync } from "fs";
import { join, dirname } from "path";
import { fileURLToPath } from "url";
import { fetchInboxEmails, modifyMessage, getOrCreateLabel } from "./gmail.js";
import { classifyAll } from "./classifier.js";
import { saveCorrection } from "./feedback.js";

const __dirname = dirname(fileURLToPath(import.meta.url));
const DATA_DIR = join(__dirname, "../data");
const CACHE_FILE = join(DATA_DIR, "cache.json");

function loadPersistedCache() {
  if (!existsSync(CACHE_FILE)) return null;
  try {
    return JSON.parse(readFileSync(CACHE_FILE, "utf-8"));
  } catch {
    return null;
  }
}

function persistCache(emails, lastScan) {
  mkdirSync(DATA_DIR, { recursive: true });
  writeFileSync(CACHE_FILE, JSON.stringify({ emails, lastScan }, null, 2));
}

const app = express();
const PORT = process.env.PORT || 3001;

app.use(cors());
app.use(express.json());

// In-memory cache: { emails: [], lastScan: Date, progress: {} }
const persisted = loadPersistedCache();
let cache = {
  emails: persisted?.emails ?? [],
  lastScan: persisted?.lastScan ?? null,
  scanning: false,
  progress: {}
};

/**
 * GET /api/emails
 * Returns cached classified emails. Triggers a scan if cache is empty.
 */
app.get("/api/emails", async (req, res) => {
  if (cache.scanning) {
    return res.json({ scanning: true, progress: cache.progress, emails: cache.emails });
  }
  res.json({ scanning: false, emails: cache.emails, lastScan: cache.lastScan });
});

/**
 * POST /api/scan
 * Triggers a fresh inbox scan (non-blocking — returns immediately, poll /api/emails)
 */
app.post("/api/scan", async (req, res) => {
  if (cache.scanning) {
    return res.json({ message: "Scan already in progress", progress: cache.progress });
  }

  // Kick off scan in background
  runScan();
  res.json({ message: "Scan started" });
});

/**
 * GET /api/progress
 * Returns current scan progress
 */
app.get("/api/progress", (req, res) => {
  res.json({ scanning: cache.scanning, progress: cache.progress });
});

/**
 * PATCH /api/emails/:id/category
 * Manually override the category of an email
 */
app.patch("/api/emails/:id/category", (req, res) => {
  const { id } = req.params;
  const { category } = req.body;
  const valid = ["action", "respond", "read", "ad", "junk"];
  if (!valid.includes(category)) return res.status(400).json({ error: "Invalid category" });

  const email = cache.emails.find(e => e.id === id);
  if (email) saveCorrection(email, email.category, category);
  cache.emails = cache.emails.map(e => e.id === id ? { ...e, category } : e);
  res.json({ success: true });
});

/**
 * POST /api/emails/:id/delete
 * Move email to trash
 */
app.post("/api/emails/:id/delete", async (req, res) => {
  const { id } = req.params;
  try {
    const result = await modifyMessage(id, {
      addLabels: ["TRASH"],
      removeLabels: ["INBOX"]
    });
    if (result.success) {
      cache.emails = cache.emails.filter(e => e.id !== id);
    }
    res.json(result);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

/**
 * POST /api/emails/:id/archive
 * Archive email (remove from inbox)
 */
app.post("/api/emails/:id/archive", async (req, res) => {
  const { id } = req.params;
  try {
    const result = await modifyMessage(id, { removeLabels: ["INBOX"] });
    if (result.success) {
      cache.emails = cache.emails.filter(e => e.id !== id);
    }
    res.json(result);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

/**
 * POST /api/emails/:id/spam
 * Move email to spam in Gmail
 */
app.post("/api/emails/:id/spam", async (req, res) => {
  const { id } = req.params;
  try {
    const result = await modifyMessage(id, {
      addLabels: ["SPAM"],
      removeLabels: ["INBOX"]
    });
    if (result.success) {
      cache.emails = cache.emails.filter(e => e.id !== id);
    }
    res.json(result);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

/**
 * POST /api/emails/:id/label
 * Apply a custom Gmail label to an email
 */
app.post("/api/emails/:id/label", async (req, res) => {
  const { id } = req.params;
  const { labelName } = req.body;
  try {
    const labelId = await getOrCreateLabel(labelName);
    const result = await modifyMessage(id, { addLabels: [labelId] });
    res.json(result);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

async function runScan() {
  cache.scanning = true;
  cache.progress = { phase: "Fetching inbox…", current: 0, total: 0 };

  try {
    // 1. Fetch emails
    const rawEmails = await fetchInboxEmails(100);

    // 2. Split into already-classified (reuse cache) and new (need classification)
    const knownMap = Object.fromEntries(cache.emails.map(e => [e.id, e]));
    const toClassify = rawEmails.filter(e => !knownMap[e.id]);
    const alreadyDone = rawEmails.filter(e => !!knownMap[e.id]);

    console.log(`Scan: ${toClassify.length} new, ${alreadyDone.length} from cache`);
    cache.progress = { phase: "Classifying…", current: 0, total: toClassify.length };

    // 3. Classify only new emails
    const newClassifications = toClassify.length > 0
      ? await classifyAll(toClassify, (p) => { cache.progress = p; })
      : [];

    // 4. Merge: cached results + new results
    const newClassMap = Object.fromEntries(newClassifications.map(c => [c.id, c]));
    cache.emails = rawEmails.map(e =>
      knownMap[e.id]
        ? { ...e, category: knownMap[e.id].category, reason: knownMap[e.id].reason, priority: knownMap[e.id].priority }
        : { ...e, ...(newClassMap[e.id] || { category: "read", reason: "Not classified", priority: 2 }) }
    );

    cache.lastScan = new Date().toISOString();
    persistCache(cache.emails, cache.lastScan);
  } catch (err) {
    console.error("Scan error:", err.message);
    cache.progress = { phase: "Error", error: err.message };
  } finally {
    cache.scanning = false;
  }
}

app.listen(PORT, () => {
  console.log(`Holdfast Mail Triage server running on http://localhost:${PORT}`);
  // Only auto-scan if no cached emails exist
  if (cache.emails.length === 0) runScan();
  else console.log(`Loaded ${cache.emails.length} emails from cache (last scan: ${cache.lastScan})`);
});
