import { readFileSync, writeFileSync, mkdirSync, existsSync } from "fs";
import { join, dirname } from "path";
import { fileURLToPath } from "url";

const __dirname = dirname(fileURLToPath(import.meta.url));
const DATA_DIR = join(__dirname, "../data");
const FILE = join(DATA_DIR, "corrections.json");
const MAX_STORED = 200;

function load() {
  if (!existsSync(FILE)) return [];
  try {
    return JSON.parse(readFileSync(FILE, "utf-8"));
  } catch {
    return [];
  }
}

function save(corrections) {
  mkdirSync(DATA_DIR, { recursive: true });
  writeFileSync(FILE, JSON.stringify(corrections, null, 2));
}

/**
 * Record a user correction.
 * @param {{ id, from, subject, snippet }} email
 * @param {string} aiCategory   - what the AI predicted
 * @param {string} userCategory - what the user changed it to
 */
export function saveCorrection(email, aiCategory, userCategory) {
  if (aiCategory === userCategory) return; // not actually a correction
  const corrections = load();
  corrections.unshift({
    from: email.from,
    subject: email.subject,
    snippet: (email.snippet || "").substring(0, 300),
    aiCategory,
    userCategory,
    timestamp: new Date().toISOString()
  });
  save(corrections.slice(0, MAX_STORED));
}

/**
 * Return the most recent N corrections as few-shot prompt examples.
 */
export function getFewShotExamples(n = 15) {
  const corrections = load();
  return corrections.slice(0, n);
}
