function priorityClass(p) {
  if (p >= 4) return 'priority--high'
  if (p === 3) return 'priority--medium'
  return 'priority--low'
}

function extractSender(from) {
  if (!from) return '(unknown)'
  const match = from.match(/^([^<]+)/)
  const name = match?.[1]?.trim()
  return name && name.length > 0 ? name : from
}

function formatDate(dateStr) {
  if (!dateStr) return ''
  try {
    const d = new Date(dateStr)
    const now = new Date()
    const diffDays = Math.floor((now - d) / 86400000)
    if (diffDays === 0) return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
    if (diffDays < 7) return d.toLocaleDateString([], { weekday: 'short' })
    return d.toLocaleDateString([], { month: 'short', day: 'numeric' })
  } catch {
    return dateStr
  }
}

export default function EmailCard({ email, selected, onSelect, onArchive, onDelete, onSpam }) {
  const { id, from, subject, date, snippet, category, reason, priority } = email

  return (
    <div className={`card card--${category}${selected ? ' card--selected' : ''}`}>
      <div className="card-header">
        <input
          type="checkbox"
          className="card-checkbox"
          checked={selected}
          onChange={e => onSelect(id, e.target.checked)}
        />
        <span className="card-sender">{extractSender(from)}</span>
        <div className="card-header-right">
          <span className={`priority ${priorityClass(priority)}`}>P{priority}</span>
          <span className="card-date">{formatDate(date)}</span>
        </div>
      </div>

      <div className="card-subject">{subject || '(no subject)'}</div>

      {snippet && <div className="card-snippet">{snippet}</div>}

      {reason && <div className="card-reason">{reason}</div>}

      <div className="card-actions">
        <div className="card-action-buttons">
          <button className="btn-action btn-action--archive" onClick={() => onArchive(id)}>Archive</button>
          <button className="btn-action btn-action--delete" onClick={() => onDelete(id)}>Delete</button>
          <button className="btn-action btn-action--spam" onClick={() => onSpam(id)}>Spam</button>
          <a className="btn-action" href={`https://mail.google.com/mail/u/0/#inbox/${id}`} target="_blank" rel="noopener noreferrer">Open ↗</a>
        </div>
      </div>
    </div>
  )
}
