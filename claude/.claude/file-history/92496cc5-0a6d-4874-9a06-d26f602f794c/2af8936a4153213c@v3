import { google } from "googleapis";

function getGmailClient() {
  const oauth2Client = new google.auth.OAuth2(
    process.env.GMAIL_CLIENT_ID,
    process.env.GMAIL_CLIENT_SECRET,
    process.env.GMAIL_REDIRECT_URI || "urn:ietf:wg:oauth:2.0:oob"
  );
  oauth2Client.setCredentials({ refresh_token: process.env.GMAIL_REFRESH_TOKEN });
  return google.gmail({ version: "v1", auth: oauth2Client });
}

/**
 * Fetch last N emails from inbox
 */
export async function fetchInboxEmails(maxResults = 100) {
  const gmail = getGmailClient();

  const listRes = await gmail.users.messages.list({
    userId: "me",
    q: "in:inbox",
    maxResults
  });

  const messages = listRes.data.messages || [];

  // Fetch headers for each message in parallel (batched to avoid rate limits)
  const BATCH = 20;
  const emails = [];

  for (let i = 0; i < messages.length; i += BATCH) {
    const batch = messages.slice(i, i + BATCH);
    const results = await Promise.all(
      batch.map(({ id }) =>
        gmail.users.messages.get({
          userId: "me",
          id,
          format: "metadata",
          metadataHeaders: ["From", "Subject", "Date"]
        }).then(res => {
          const headers = Object.fromEntries(
            (res.data.payload?.headers || []).map(h => [h.name, h.value])
          );
          return {
            id,
            from: headers["From"] || "",
            subject: headers["Subject"] || "(no subject)",
            date: headers["Date"] || "",
            snippet: res.data.snippet || ""
          };
        })
      )
    );
    emails.push(...results);
  }

  return emails;
}

/**
 * Fetch full body of a single message
 */
export async function fetchMessageBody(messageId) {
  const gmail = getGmailClient();
  const res = await gmail.users.messages.get({
    userId: "me",
    id: messageId,
    format: "full"
  });

  // Extract plain text body
  const parts = res.data.payload?.parts || [];
  const textPart = parts.find(p => p.mimeType === "text/plain");
  let body = "";
  if (textPart?.body?.data) {
    body = Buffer.from(textPart.body.data, "base64").toString("utf-8").substring(0, 1000);
  }

  return { body, threadCount: 1 };
}

/**
 * Modify a message — add/remove labels
 */
export async function modifyMessage(messageId, { addLabels = [], removeLabels = [] }) {
  const gmail = getGmailClient();
  try {
    await gmail.users.messages.modify({
      userId: "me",
      id: messageId,
      requestBody: {
        addLabelIds: addLabels,
        removeLabelIds: removeLabels
      }
    });
    return { success: true };
  } catch (err) {
    return { success: false, error: err.message };
  }
}

/**
 * Get or create a Gmail label by name, return its ID
 */
export async function getOrCreateLabel(labelName) {
  const gmail = getGmailClient();

  const listRes = await gmail.users.labels.list({ userId: "me" });
  const existing = (listRes.data.labels || []).find(l => l.name === labelName);
  if (existing) return existing.id;

  const createRes = await gmail.users.labels.create({
    userId: "me",
    requestBody: { name: labelName }
  });
  return createRes.data.id;
}
