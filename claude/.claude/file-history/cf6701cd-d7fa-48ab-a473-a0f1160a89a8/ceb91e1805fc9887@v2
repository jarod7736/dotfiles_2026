const CATEGORIES = [
  { key: 'action',  label: 'Action Required' },
  { key: 'respond', label: 'Respond' },
  { key: 'read',    label: 'Read' },
  { key: 'ad',      label: 'Ad' },
  { key: 'junk',    label: 'Junk' },
]

export default function BulkActionBar({ count, onClassify, onArchive, onDelete, onSpam, onClear, onSelectAll }) {
  if (count === 0) return null

  return (
    <div className="bulk-bar">
      <span className="bulk-count">{count} selected</span>

      <div className="bulk-classify">
        {CATEGORIES.map(({ key, label }) => (
          <button key={key} className={`bulk-btn bulk-btn--cat bulk-btn--${key}`} onClick={() => onClassify(key)}>
            {label}
          </button>
        ))}
      </div>

      <div className="bulk-actions">
        <button className="bulk-btn bulk-btn--archive" onClick={onArchive}>Archive</button>
        <button className="bulk-btn bulk-btn--delete" onClick={onDelete}>Delete</button>
        <button className="bulk-btn bulk-btn--spam" onClick={onSpam}>Spam</button>
      </div>

      <div className="bulk-controls">
        <button className="bulk-btn bulk-btn--select-all" onClick={onSelectAll}>Select All</button>
        <button className="bulk-btn bulk-btn--clear" onClick={onClear}>Clear</button>
      </div>
    </div>
  )
}
