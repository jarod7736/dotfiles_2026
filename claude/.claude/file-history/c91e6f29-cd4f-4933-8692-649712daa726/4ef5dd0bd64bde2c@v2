export default function ProgressBar({ scanning, progress }) {
  if (!scanning) return null

  const { phase = '', current = 0, total = 0 } = progress
  const isIndeterminate = total === 0 || phase.toLowerCase().includes('fetch')
  const pct = isIndeterminate ? null : Math.round((current / total) * 100)

  return (
    <div className="progress-wrap">
      <div className="progress-label">
        <span>{phase || 'Working…'}</span>
        {!isIndeterminate && <span>{current} / {total}</span>}
      </div>
      <div className="progress-track">
        {isIndeterminate
          ? <div className="progress-fill progress-fill--indeterminate" />
          : <div className="progress-fill" style={{ width: `${pct}%` }} />
        }
      </div>
    </div>
  )
}
