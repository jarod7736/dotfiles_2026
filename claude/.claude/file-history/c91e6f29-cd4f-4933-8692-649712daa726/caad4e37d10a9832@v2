import { useMemo } from 'react'
import { useEmailTriage } from './hooks/useEmailTriage.js'
import ProgressBar from './components/ProgressBar.jsx'
import CategoryColumn from './components/CategoryColumn.jsx'

const CATEGORIES = ['action', 'respond', 'read', 'ad', 'junk']

function formatLastScan(isoStr) {
  if (!isoStr) return null
  try {
    const d = new Date(isoStr)
    const diffMin = Math.floor((Date.now() - d) / 60000)
    if (diffMin < 1) return 'just now'
    if (diffMin === 1) return '1 min ago'
    if (diffMin < 60) return `${diffMin} min ago`
    return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
  } catch {
    return null
  }
}

export default function App() {
  const { emails, scanning, progress, lastScan, error, triggerScan, reclassifyEmail, spamEmail } = useEmailTriage()

  const byCategory = useMemo(() => {
    const sorted = [...emails].sort((a, b) => (b.priority ?? 0) - (a.priority ?? 0))
    return Object.fromEntries(
      CATEGORIES.map(cat => [cat, sorted.filter(e => e.category === cat)])
    )
  }, [emails])

  return (
    <div className="app">
      <header className="app-header">
        <h1>Holdfast Mail Triage</h1>
        <div className="header-controls">
          {lastScan && (
            <span className="last-scan">Last scan: {formatLastScan(lastScan)}</span>
          )}
          {error && (
            <span style={{ color: '#f87171', fontSize: 12 }}>⚠ {error}</span>
          )}
          <button className="btn-refresh" onClick={triggerScan} disabled={scanning}>
            {scanning ? 'Scanning…' : 'Refresh'}
          </button>
        </div>
      </header>

      <ProgressBar scanning={scanning} progress={progress} />

      <main className="kanban-board">
        {CATEGORIES.map(cat => (
          <CategoryColumn
            key={cat}
            category={cat}
            emails={byCategory[cat] ?? []}
            defaultCollapsed={cat === 'ad' || cat === 'junk'}
            onReclassify={reclassifyEmail}
            onSpam={spamEmail}
          />
        ))}
      </main>
    </div>
  )
}
