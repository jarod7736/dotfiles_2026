import { useState, useEffect, useCallback } from 'react'

export function useEmailTriage() {
  const [emails, setEmails] = useState([])
  const [scanning, setScanning] = useState(false)
  const [progress, setProgress] = useState({ phase: '', current: 0, total: 0 })
  const [lastScan, setLastScan] = useState(null)
  const [error, setError] = useState(null)

  const fetchEmails = useCallback(async () => {
    try {
      const res = await fetch('/api/emails')
      const data = await res.json()
      if (data.emails) setEmails(data.emails)
      if (data.lastScan) setLastScan(data.lastScan)
      if (data.progress) setProgress(data.progress)
      setScanning(!!data.scanning)
      return data
    } catch (err) {
      setError(err.message)
      return {}
    }
  }, [])

  const triggerScan = useCallback(async () => {
    if (scanning) return
    try {
      await fetch('/api/scan', { method: 'POST' })
      setScanning(true)
      setProgress({ phase: 'Fetching inbox…', current: 0, total: 0 })
    } catch (err) {
      setError(err.message)
    }
  }, [scanning])

  // On mount: check if a scan is already running or cache is empty
  useEffect(() => {
    fetchEmails().then(data => {
      if (data.scanning) {
        // Server is mid-scan (started on boot) — polling useEffect will pick up
      } else if (!data.emails || data.emails.length === 0) {
        triggerScan()
      }
    })
  }, []) // eslint-disable-line react-hooks/exhaustive-deps

  // Poll progress while scanning
  useEffect(() => {
    if (!scanning) return
    const id = setInterval(async () => {
      try {
        const res = await fetch('/api/progress')
        const data = await res.json()
        if (data.progress) setProgress(data.progress)
        if (!data.scanning) {
          clearInterval(id)
          fetchEmails()
        }
      } catch (err) {
        setError(err.message)
        clearInterval(id)
      }
    }, 1500)
    return () => clearInterval(id)
  }, [scanning, fetchEmails])

  const reclassifyEmail = useCallback(async (id, category) => {
    const snapshot = emails
    setEmails(prev => prev.map(e => e.id === id ? { ...e, category } : e))
    try {
      const res = await fetch(`/api/emails/${id}/category`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category })
      })
      if (!res.ok) throw new Error('Failed to reclassify')
    } catch (err) {
      setEmails(snapshot)
      setError(err.message)
    }
  }, [emails])

  const deleteEmail = useCallback(async (id) => {
    if (!window.confirm('Move to trash?')) return
    const snapshot = emails
    setEmails(prev => prev.filter(e => e.id !== id))
    try {
      const res = await fetch(`/api/emails/${id}/delete`, { method: 'POST' })
      if (!res.ok) throw new Error('Failed to delete')
    } catch (err) {
      setEmails(snapshot)
      setError(err.message)
    }
  }, [emails])

  const archiveEmail = useCallback(async (id) => {
    const snapshot = emails
    setEmails(prev => prev.filter(e => e.id !== id))
    try {
      const res = await fetch(`/api/emails/${id}/archive`, { method: 'POST' })
      if (!res.ok) throw new Error('Failed to archive')
    } catch (err) {
      setEmails(snapshot)
      setError(err.message)
    }
  }, [emails])

  const spamEmail = useCallback(async (id) => {
    if (!window.confirm('Move to spam?')) return
    const snapshot = emails
    setEmails(prev => prev.filter(e => e.id !== id))
    try {
      const res = await fetch(`/api/emails/${id}/spam`, { method: 'POST' })
      if (!res.ok) throw new Error('Failed to move to spam')
    } catch (err) {
      setEmails(snapshot)
      setError(err.message)
    }
  }, [emails])

  return { emails, scanning, progress, lastScan, error, triggerScan, reclassifyEmail, archiveEmail, deleteEmail, spamEmail }
}
